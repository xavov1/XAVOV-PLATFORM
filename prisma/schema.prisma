model Order {
  id            String   @id @default(cuid())
  email         String?
  phone         String?
  name          String?
  address       String?
  paymentMethod String?  @default("card")
  totalAmount   Float
  status        String   @default("processing")
  items         Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}