generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
}

model Order {
  id        String   @id @default(cuid())
  total     Float
  status    String
  createdAt DateTime @default(now())
}

model OTP {
  id         String   @id @default(cuid())
  identifier String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}