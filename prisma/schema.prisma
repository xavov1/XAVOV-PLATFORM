generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id            String   @id @default(uuid())
  fullName      String
  phone         String
  address       String
  latitude      Float?
  longitude     Float?
  items         Json
  total         Float

  paymentStatus String   @default("pending")
  orderStatus   String   @default("pending")

  createdAt     DateTime @default(now())
}